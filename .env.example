# ─────────────────────────────────────────────────────────────
# Supabase  (see SUPABASE_SETUP.md for how to obtain these)
# ─────────────────────────────────────────────────────────────
# Project URL, e.g. https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# "anon / public" key — safe to expose to the browser (RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# "service_role" key — SERVER ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Admin login (stored in env, no user management yet)
# ─────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=@dm!n
# Secret used to sign the admin session cookie (any long random string)
ADMIN_SESSION_SECRET=please-generate-a-long-random-string

# ─────────────────────────────────────────────────────────────
# Restaurant defaults (used as fallback before settings load,
# and as the default values for the seed row).
# The live values are read from the restaurant_settings table.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_RESTAURANT_NAME=The Belgian Waffle Xpress
# WhatsApp number in international format WITHOUT + or spaces, e.g. 919876543210
NEXT_PUBLIC_RESTAURANT_WHATSAPP=919876543210
NEXT_PUBLIC_PRIMARY_COLOR=#d97706
NEXT_PUBLIC_SECONDARY_COLOR=#7c2d12
